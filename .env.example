# Copy to .env.local for local tooling (never commit secrets).
# On Vercel: Project → Settings → Environment Variables (same names).

# --- Supabase (https://supabase.com/dashboard/project/_/settings/api) ---
# Public: safe in browser with Row Level Security policies enabled (e.g. admin / future client reads).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key

# Server-only: use in /api routes only. Never prefix with NEXT_PUBLIC_ or expose in static HTML.
# Required for /api/bookings and /api/waitlist to write to the same Supabase project as above.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: Resend (https://resend.com) for booking status emails (confirmed/cancelled) from admin APIs
# RESEND_API_KEY=
# BOOKING_FROM_EMAIL=Wildfire Raceway <onboarding@resend.dev>

# --- Admin dashboard (/admin) ---
# Required: password for POST /api/admin/login (set on Vercel for production).
ADMIN_DASHBOARD_PASSWORD=change-me-in-production
# Optional: separate HMAC secret for session cookies (defaults to ADMIN_DASHBOARD_PASSWORD if unset).
# ADMIN_SESSION_SECRET=

# Vite (optional local dev for admin UI — mirror Supabase dashboard “anon” + URL for future client features).
# VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: database direct URL for migrations (server/CI only)
# SUPABASE_DB_URL=postgresql://postgres:...

# --- xAI Grok (server-side proxy — do not call from browser with secret key) ---
# Used by /api/chat (required for Campus Assistant).
XAI_API_KEY=
# Optional override (default on server: grok-2-latest)
# XAI_MODEL=grok-2-latest

# --- Site / redirects (optional) ---
# Vercel sets VERCEL_URL automatically. Override for canonical links:
# SITE_URL=https://your-domain.com
